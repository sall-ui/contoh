// ── CATEGORY CONFIG ──────────────────────────────────
const CATS = [
  { key:"all", label:"Semua", cls:"cat-all" },
  { key:"Eliminasi & Kebersihan", label:"Eliminasi", cls:"cat-elim" },
  { key:"Perawatan Diri & Mulut", label:"Perawatan Diri", cls:"cat-perawatan" },
  { key:"Makanan & Minuman", label:"Makanan", cls:"cat-makanan" },
  { key:"Mobilitas & Alat Bantu", label:"Mobilitas", cls:"cat-mobilitas" },
  { key:"Penyakit & Gejala", label:"Penyakit", cls:"cat-penyakit" },
  { key:"Posisi & Postur", label:"Posisi", cls:"cat-posisi" },
];

const CAT_ACCENT = {
  "Eliminasi & Kebersihan": "#c0392b",
  "Perawatan Diri & Mulut": "#8e44ad",
  "Makanan & Minuman": "#d4a017",
  "Mobilitas & Alat Bantu": "#27ae60",
  "Penyakit & Gejala": "#2980b9",
  "Posisi & Postur": "#e67e22",
};

// ── STATE ────────────────────────────────────────────
let currentFilter = 'all';
let learned = new Set();
let displayOrder = [];

// ── RENDER PILLS ─────────────────────────────────────
function renderPills() {
  const strip = document.getElementById('categoryStrip');
  strip.innerHTML = '';
  CATS.forEach(c => {
    const pill = document.createElement('button');
    pill.className = 'cat-pill ' + c.cls + (currentFilter === c.key ? ' active' : '');
    pill.textContent = c.label;
    pill.addEventListener('click', () => {
      currentFilter = c.key;
      document.getElementById('categorySelect').value = c.key;
      renderPills();
      renderDeck();
    });
    strip.appendChild(pill);
  });
}

// ── FILTERED DATA ────────────────────────────────────
function filteredData() {
  if (currentFilter === 'all') return displayOrder.map(i => DATA[i]);
  return displayOrder.map(i => DATA[i]).filter(d => d.cat === currentFilter);
}

// ── SHUFFLE ──────────────────────────────────────────
function shuffle(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

// ── UPDATE PROGRESS ───────────────────────────────────
function updateProgress() {
  const fd = filteredData();
  const total = fd.length;
  const learnedInView = fd.filter(d => learned.has(d.kanji)).length;
  document.getElementById('learnedCount').textContent = learnedInView;
  document.getElementById('totalCount').textContent = total;
  const pct = total === 0 ? 0 : (learnedInView / total * 100);
  document.getElementById('progressFill').style.width = pct + '%';
}

// ── RENDER DECK ───────────────────────────────────────
function renderDeck() {
  const deck = document.getElementById('deckArea');
  deck.innerHTML = '';
  const cards = filteredData();

  updateProgress();

  if (cards.length === 0) {
    deck.innerHTML = '<div class="empty-state"><span class="em-kanji">無</span><p>Tidak ada kartu untuk kategori ini.</p></div>';
    return;
  }

  cards.forEach((d, idx) => {
    const isLearned = learned.has(d.kanji);
    const accent = CAT_ACCENT[d.cat] || '#1a1410';

    const scene = document.createElement('div');
    scene.className = 'card-scene' + (isLearned ? ' learned' : '');
    scene.dataset.kanji = d.kanji;

    const inner = document.createElement('div');
    inner.className = 'card-inner';

    // FRONT
    const front = document.createElement('div');
    front.className = 'card-face card-front';
    front.style.borderColor = accent;
    front.style.boxShadow = `4px 4px 0 ${accent}`;

    front.innerHTML = `
      <div class="card-header-bar">
        <span class="card-category-tag">${d.cat}</span>
        <span class="card-num">#${String(idx+1).padStart(2,'0')}</span>
      </div>
      <div class="card-front-body">
        <div class="kanji-main">${d.kanji}</div>
      </div>
      <div class="card-front-hint">タップして確認 — Klik untuk lihat jawaban</div>
    `;

    // BACK
    const back = document.createElement('div');
    back.className = 'card-face card-back';
    back.innerHTML = `
      <div class="back-kana">${d.kana}</div>
      <div class="back-divider"></div>
      <div class="back-meaning">${d.arti}</div>
      <div class="back-kanji-ghost">${d.kanji}</div>
      <button class="mark-btn" title="Tandai sudah dipelajari">✓</button>
    `;

    // Stamp
    const stamp = document.createElement('div');
    stamp.className = 'learned-stamp';
    stamp.textContent = '習得';

    inner.appendChild(front);
    inner.appendChild(back);
    scene.appendChild(inner);
    scene.appendChild(stamp);

    // Flip on click (excluding mark button)
    scene.addEventListener('click', (e) => {
      if (e.target.closest('.mark-btn')) return;
      scene.classList.toggle('flipped');
    });

    // Mark learned
    const markBtn = back.querySelector('.mark-btn');
    markBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (learned.has(d.kanji)) {
        learned.delete(d.kanji);
        scene.classList.remove('learned');
      } else {
        learned.add(d.kanji);
        scene.classList.add('learned');
        // auto-flip back after a moment
        setTimeout(() => scene.classList.remove('flipped'), 600);
      }
      updateProgress();
    });

    deck.appendChild(scene);
  });
}

// ── INIT ─────────────────────────────────────────────
function init() {
  displayOrder = DATA.map((_, i) => i);

  // category select
  document.getElementById('categorySelect').addEventListener('change', (e) => {
    currentFilter = e.target.value;
    renderPills();
    renderDeck();
  });

  // shuffle
  document.getElementById('shuffleBtn').addEventListener('click', () => {
    shuffle(displayOrder);
    renderDeck();
  });

  // reset
  document.getElementById('resetBtn').addEventListener('click', () => {
    learned.clear();
    displayOrder = DATA.map((_, i) => i);
    renderDeck();
  });

  renderPills();
  renderDeck();
}

document.addEventListener('DOMContentLoaded', init);
</script>
